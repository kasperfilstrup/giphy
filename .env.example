# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; .env.example is committed so new contributors and CI
# know which variables are required.

# Giphy API key. Server-only — must NOT be prefixed with NEXT_PUBLIC_ because
# that would inline the value into the client JS bundle and leak the secret.
# Read from process.env.GIPHY_API_KEY in app/api/search/route.ts.
GIPHY_API_KEY=
